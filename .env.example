# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string — Railway injects this automatically when you
# add a PostgreSQL service. Copy it from the Railway dashboard for local dev.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be at least 32 random characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-secret-key-min-32-chars
JWT_EXPIRES_IN=7d

# ── Environment ───────────────────────────────────────────────────────────────
# Set to 'production' on Railway — enables SSL for the database connection.
NODE_ENV=development

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys and your product/price IDs
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...

# ── App ───────────────────────────────────────────────────────────────────────
# Used as the base URL for Stripe success/cancel redirects.
# Local: http://localhost:3000   Production: your Railway URL
APP_URL=https://auditpilot-production.up.railway.app

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Admin (dev/testing only) ──────────────────────────────────────────────────
# Protects /api/admin/* endpoints. Pass as X-Admin-Secret header.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_SECRET=your-random-admin-secret
